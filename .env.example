# ─────────────────────────────────────────────
#  WhatsApp Microservice — Environment Variables
#  انسخ هذا الملف إلى .env وعدّل القيم
# ─────────────────────────────────────────────

# ───── App API Security ─────
API_SECRET_KEY=my_super_secret_key_123

# ───── Database (PostgreSQL) ─────
DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@localhost:5432/whatsapp_data

# ───── Redis ─────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password   # أزل التعليق إذا كان Redis محمياً بكلمة مرور

# ───── Security Rules ─────
OTP_EXPIRATION_MINUTES=5
MAX_FAILED_ATTEMPTS=3
BLOCK_DURATION_MINUTES=15

# ───── WhatsApp Provider ─────
# Options: 'evolution' or 'meta'
WHATSAPP_PROVIDER=evolution

# ───── WhatsApp Evolution API ─────
EVOLUTION_API_URL=http://127.0.0.1:8080
EVOLUTION_API_TOKEN=my_evolution_token_123
EVOLUTION_INSTANCE_NAME=moha
EVOLUTION_INSTANCE_ID=moha

# ───── WhatsApp Meta Cloud API ─────
META_API_TOKEN=your_meta_access_token_here
META_PHONE_NUMBER_ID=your_meta_phone_id_here
META_API_VERSION=v19.0

# ───── Presentation Mode ─────
# True  = محاكاة الإرسال (للعرض أمام اللجنة)
# False = إرسال حقيقي
WHATSAPP_MOCK_MODE=True
